<Window x:Class="BarbatosWpfApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:aq="http://schemas.barbatos.dev/aquarius"
        aq:Setup.Enable="True"
        Title="BarbatosWpfApp" Height="450" Width="800">
    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
        <TextBlock Text="{Binding Greeting}" FontSize="18" Margin="0,0,0,16" />
        <TextBlock Text="{Binding Count.Value}" FontSize="32" HorizontalAlignment="Center" />
        <Button Content="Count" Command="{Binding IncrementCommand}" Padding="20,8" Margin="0,16,0,0" HorizontalAlignment="Center" />
    </StackPanel>
</Window>
