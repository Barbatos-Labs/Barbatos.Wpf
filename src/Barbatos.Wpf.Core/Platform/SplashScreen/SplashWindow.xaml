<Window x:Class="Barbatos.Wpf.Hosting.SplashWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        ShowInTaskbar="False"
        Topmost="True"
        SizeToContent="WidthAndHeight"
        Background="White">
    <Border BorderBrush="#DDDDDD" BorderThickness="1" Padding="32">
        <StackPanel HorizontalAlignment="Center" MinWidth="320" MaxWidth="480">
            <Image x:Name="LogoImage"
                   x:FieldModifier="public"
                   Width="96"
                   Height="96"
                   Margin="0,0,0,16"
                   Stretch="Uniform"
                   HorizontalAlignment="Center" />

            <TextBlock x:Name="AppNameText"
                       x:FieldModifier="public"
                       FontSize="22"
                       FontWeight="SemiBold"
                       HorizontalAlignment="Center"
                       TextAlignment="Center"
                       TextWrapping="Wrap" />

            <TextBlock x:Name="TaglineText"
                       x:FieldModifier="public"
                       Margin="0,4,0,0"
                       FontSize="12"
                       Foreground="Gray"
                       HorizontalAlignment="Center"
                       TextAlignment="Center"
                       TextWrapping="Wrap" />

            <ProgressBar x:Name="ProgressIndicator"
                         x:FieldModifier="public"
                         Height="4"
                         Margin="0,24,0,0"
                         IsIndeterminate="True" />

            <ItemsControl x:Name="SponsorLogosControl" x:FieldModifier="public" Margin="0,20,0,0" HorizontalAlignment="Center">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <StackPanel Orientation="Horizontal" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
            </ItemsControl>

            <Separator x:Name="RelatedLinksSeparator" x:FieldModifier="public" Margin="0,16,0,8" />

            <ItemsControl x:Name="RelatedLinksControl" x:FieldModifier="public" HorizontalAlignment="Stretch" />
        </StackPanel>
    </Border>
</Window>
