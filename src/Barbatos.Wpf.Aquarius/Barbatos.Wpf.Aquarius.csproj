<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <PackageId>Barbatos.Wpf.Aquarius</PackageId>
    <TargetFrameworks>net10.0-windows10.0.17763.0;net9.0-windows10.0.17763.0;net8.0-windows10.0.17763.0</TargetFrameworks>
    <GeneratePackageOnBuild>true</GeneratePackageOnBuild>
    <UseWPF>true</UseWPF>
    <!-- Full override, not an append to the shared $(CommonTags) - that shared value bakes in
         Core-specific words ("hosting;setup;foundation") that don't describe Aquarius and would
         mislead NuGet search. -->
    <CommonTags>dotnet;wpf;windows;presentation;vue;vuejs;reactivity;mvvm;directives;teleport;animation;xaml</CommonTags>
    <Description>Barbatos.Wpf.Aquarius - Vue.js-inspired reactivity, lifecycle hooks, directives, Teleport, and Transitions for WPF</Description>
    <RootNamespace>Barbatos.Wpf</RootNamespace>
    <!-- WPF does not support trimming/AOT, so the configuration-binding trim warnings do not apply.
         IL2075 additionally covers Directives.Event's own use of reflection (Type.GetEvent) to wire
         up an arbitrary named event, which is inherently dynamic by design (see its XML docs). -->
    <NoWarn>$(NoWarn);IL2026;IL3050;IL2075</NoWarn>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="CommunityToolkit.Mvvm" />
  </ItemGroup>

</Project>
