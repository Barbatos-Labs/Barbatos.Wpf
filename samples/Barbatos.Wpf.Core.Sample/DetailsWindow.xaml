<Window x:Class="Barbatos.Wpf.Core.Sample.DetailsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Details" Height="180" Width="360"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize">
    <StackPanel Margin="16">
        <TextBlock Text="Details" FontWeight="SemiBold" FontSize="16" />
        <TextBlock x:Name="OwnerText" Margin="0,8,0,0" Foreground="Gray" FontSize="11" TextWrapping="Wrap" />
        <CheckBox x:Name="VetoCloseCheckBox"
                  Content="Veto closing (simulate unsaved work)"
                  Margin="0,16,0,0" />
    </StackPanel>
</Window>
