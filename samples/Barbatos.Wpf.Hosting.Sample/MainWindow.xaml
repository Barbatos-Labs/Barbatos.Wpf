<Window x:Class="Barbatos.Wpf.Hosting.Sample.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Barbatos.Wpf.Hosting.Sample"
        mc:Ignorable="d"
        d:DataContext="{d:DesignInstance Type=local:MainViewModel}"
        Title="Barbatos.Wpf.Hosting Sample" Height="450" Width="800">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Text="{Binding Greeting}"
                   FontSize="20"
                   FontWeight="SemiBold"
                   TextWrapping="Wrap" />

        <TextBlock Grid.Row="1"
                   Margin="0,8,0,0"
                   Text="{Binding EnvironmentDescription}"
                   Foreground="Gray"
                   TextWrapping="Wrap" />

        <TextBlock Grid.Row="2"
                   Margin="0,16,0,4"
                   Text="Lifecycle events:"
                   FontWeight="SemiBold" />

        <ListBox Grid.Row="3"
                 ItemsSource="{Binding LifecycleEvents}"
                 FontFamily="Consolas" />
    </Grid>
</Window>
