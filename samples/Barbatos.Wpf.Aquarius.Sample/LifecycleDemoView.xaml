<UserControl x:Class="Barbatos.Wpf.Aquarius.Sample.LifecycleDemoView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:aq="http://schemas.barbatos.dev/aquarius"
             aq:Lifecycle.Enable="True">
    <Border Background="#14000000"
            BorderBrush="Gray"
            BorderThickness="1"
            Padding="8"
            Margin="0,4,0,0">
        <StackPanel>
            <TextBlock FontStyle="Italic"
                       TextWrapping="Wrap"
                       Text="This child's DataContext implements IOnBeforeMount/IOnMounted/IOnUpdated/IOnUnmounted - see the activity log." />
            <TextBlock Margin="0,4,0,4"
                       Text="{Binding Ticks, StringFormat='Ticks: {0}'}" />
            <StackPanel Orientation="Horizontal">
                <Button Content="Tick"
                        Margin="0,0,8,0"
                        Command="{Binding TickCommand}" />
                <Button Content="Tick twice (batches to one OnUpdated)"
                        Command="{Binding TickTwiceCommand}" />
            </StackPanel>

            <TextBlock Margin="0,12,0,4"
                       FontStyle="Italic"
                       TextWrapping="Wrap"
                       Text="IOnMountedAsync + Suspense - fires alongside OnMounted above, awaits 1.2s, then resolves. Toggle this demo off/on to see it fire fresh on every remount, not just once:" />
            <aq:Suspense IsPending="{Binding IsLoadingDashboard}">
                <Border Background="#E5F7E5"
                        Padding="8">
                    <TextBlock Text="{Binding DashboardData}" />
                </Border>
                <aq:Suspense.Fallback>
                    <Border Background="#FFF6E0"
                            Padding="8">
                        <TextBlock Text="Loading (OnMountedAsync awaiting)..." />
                    </Border>
                </aq:Suspense.Fallback>
            </aq:Suspense>
        </StackPanel>
    </Border>
</UserControl>
