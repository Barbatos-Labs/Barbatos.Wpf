<UserControl x:Class="Barbatos.Wpf.Aquarius.Sample.TeleportDemoView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:Barbatos.Wpf.Aquarius.Sample"
             xmlns:aq="http://schemas.barbatos.co/aquarius/2026/xaml">
    <StackPanel Margin="12">
        <TextBlock TextWrapping="Wrap"
                   FontWeight="Bold"
                   Margin="0,0,0,8"
                   Text="Toast - escapes nested layout/clipping" />
        <TextBlock TextWrapping="Wrap"
                   Margin="0,0,0,8"
                   Text="The toast below is declared inside a clipped, fixed-height box, but Teleport renders it pinned at the window's top-right corner." />
        <Button HorizontalAlignment="Left"
                Content="Toggle toast"
                Command="{Binding ToggleToastCommand}" />
        <Border BorderBrush="Gray"
                BorderThickness="1"
                Height="70"
                ClipToBounds="True"
                Margin="0,8,0,20">
            <GroupBox Header="deeply nested + clipped">
                <Border>
                    <aq:If Condition="{Binding ShowToast}">
                        <aq:Teleport To="Overlay">
                            <!-- Explicit DataContext, not inherited: once Teleport moves this
                                 into the "Overlay" host (a sibling of this whole tab, outside
                                 its DataContext scope), inheritance would otherwise resolve
                                 against whatever *that* host's ancestors provide instead - see
                                 the README's Teleport section for this exact gotcha. -->
                            <local:ToastView DataContext="{Binding}" />
                        </aq:Teleport>
                    </aq:If>
                </Border>
            </GroupBox>
        </Border>

        <TextBlock TextWrapping="Wrap"
                   FontWeight="Bold"
                   Margin="0,0,0,8"
                   Text="Dockable panel - the same primitive, extended" />
        <TextBlock TextWrapping="Wrap"
                   Margin="0,0,0,8"
                   Text="Undock opens a real second Window with its own registered host; retargeting the same Teleport moves the panel there and back, keeping whatever you typed. Try closing the floating window with its own [X] instead of clicking Redock - TeleportHost.HostUnregistered still brings it home automatically." />
        <StackPanel Orientation="Horizontal"
                    Margin="0,0,0,8">
            <Button Content="Undock"
                    Margin="0,0,8,0"
                    Command="{Binding UndockCommand}" />
            <Button Content="Redock"
                    Command="{Binding RedockCommand}" />
        </StackPanel>

        <TextBlock TextWrapping="Wrap"
                   Margin="0,0,0,4"
                   FontStyle="Italic"
                   Text="Docked home slot (empty while undocked):" />
        <Border BorderBrush="Gray"
                BorderThickness="1"
                MinHeight="70"
                Padding="4">
            <Grid aq:TeleportHost.RegisterHost="MainDock" />
        </Border>

        <aq:Teleport To="{Binding DockTarget.Value}">
            <Border Background="#E0F0FF"
                    Padding="8"
                    Margin="0,8,0,0">
                <StackPanel>
                    <TextBlock TextWrapping="Wrap"
                               Text="Dockable panel content - same TextBox instance the whole time:" />
                    <TextBox Margin="0,4,0,0"
                             aq:Directives.Model="{Binding DockableNotes}" />
                </StackPanel>
            </Border>
        </aq:Teleport>
    </StackPanel>
</UserControl>
