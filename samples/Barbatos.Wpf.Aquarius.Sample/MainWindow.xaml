<Window x:Class="Barbatos.Wpf.Aquarius.Sample.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Barbatos.Wpf.Aquarius.Sample"
        xmlns:aq="http://schemas.barbatos.dev/aquarius"
        mc:Ignorable="d"
        d:DataContext="{d:DesignInstance Type=local:MainViewModel}"
        Title="Barbatos.Wpf.Aquarius Sample"
        Height="900"
        Width="640">
    <Window.Resources>
        <Storyboard x:Key="FadeSlideIn">
            <DoubleAnimation Storyboard.TargetProperty="Opacity"
                              From="0" To="1" Duration="0:0:0.25" />
        </Storyboard>
        <Storyboard x:Key="FadeSlideOut">
            <DoubleAnimation Storyboard.TargetProperty="Opacity"
                              From="1" To="0" Duration="0:0:0.25" />
        </Storyboard>
        <Storyboard x:Key="LogEnter">
            <DoubleAnimation Storyboard.TargetProperty="Opacity"
                              From="0" To="1" Duration="0:0:0.4" />
        </Storyboard>
    </Window.Resources>

    <!--
        Each tab below is a fully self-contained View+ViewModel pair (see e.g.
        ReactivityDemoView/ReactivityDemoViewModel) - this shell only wires each one's
        DataContext to its own property on MainViewModel and hosts the two things that
        genuinely need to live above every tab: the shared activity log, and the Teleport
        "Overlay" host (so a toast pinned there isn't clipped by whichever tab is selected).
    -->
    <Grid aq:Provide.Key="ThemeColor"
          aq:Provide.Value="{Binding ProvideInjectDemo.ThemeColor.Value}">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TabControl Grid.Row="0"
                    Margin="8">
            <TabItem Header="Reactivity">
                <local:ReactivityDemoView DataContext="{Binding ReactivityDemo}" />
            </TabItem>

            <TabItem Header="Lifecycle">
                <StackPanel Margin="12">
                    <TextBlock TextWrapping="Wrap"
                               Margin="0,0,0,8"
                               Text="Toggling mounts/unmounts (and now animates) the child - see the activity log below." />
                    <Button HorizontalAlignment="Left"
                            Content="Toggle lifecycle demo"
                            Command="{Binding ToggleLifecycleDemoCommand}" />
                    <aq:Transition Show="{Binding ShowLifecycleDemo}"
                                   Enter="{StaticResource FadeSlideIn}"
                                   Leave="{StaticResource FadeSlideOut}">
                        <local:LifecycleDemoView DataContext="{Binding LifecycleDemo}" />
                    </aq:Transition>
                </StackPanel>
            </TabItem>

            <TabItem Header="Directives">
                <local:DirectivesDemoView DataContext="{Binding DirectivesDemo}" />
            </TabItem>

            <TabItem Header="Teleport">
                <local:TeleportDemoView DataContext="{Binding TeleportDemo}" />
            </TabItem>

            <TabItem Header="Provide / Inject">
                <local:ProvideInjectDemoView DataContext="{Binding ProvideInjectDemo}" />
            </TabItem>

            <TabItem Header="Suspense">
                <local:SuspenseDemoView DataContext="{Binding SuspenseDemo}" />
            </TabItem>

            <TabItem Header="Slots">
                <local:SlotsDemoView DataContext="{Binding SlotsDemo}" />
            </TabItem>

            <TabItem Header="Expr">
                <local:ExprDemoView DataContext="{Binding ExprDemo}" />
            </TabItem>
        </TabControl>

        <GroupBox Grid.Row="1"
                  Header="Activity log (each new entry fades in via TransitionGroup.Enter)"
                  Margin="8,0,8,8">
            <ListBox Height="140"
                     ItemsSource="{Binding ActivityLog}"
                     VirtualizingPanel.IsVirtualizing="False"
                     aq:TransitionGroup.Enter="{StaticResource LogEnter}" />
        </GroupBox>

        <Grid Grid.RowSpan="2"
              Margin="0,12,12,0"
              HorizontalAlignment="Stretch"
              VerticalAlignment="Stretch"
              aq:TeleportHost.RegisterHost="Overlay" />
    </Grid>
</Window>
