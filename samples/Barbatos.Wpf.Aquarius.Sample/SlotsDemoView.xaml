<UserControl x:Class="Barbatos.Wpf.Aquarius.Sample.SlotsDemoView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:Barbatos.Wpf.Aquarius.Sample"
             xmlns:aq="http://schemas.barbatos.dev/aquarius">
    <UserControl.Resources>
        <!-- Card's own ControlTemplate - a component author picks named slots back out of
             whatever the consumer supplied, with SlotProvided skipping each wrapper Border
             entirely when that slot wasn't used (Vue's own Conditional Slots pattern). -->
        <Style TargetType="{x:Type local:Card}">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type local:Card}">
                        <Border BorderBrush="Gray"
                                BorderThickness="1"
                                CornerRadius="4">
                            <StackPanel>
                                <aq:If Condition="{aq:SlotProvided header}">
                                    <Border Background="#F0F0F0"
                                            Padding="8">
                                        <ContentPresenter Content="{aq:SlotContent header}" />
                                    </Border>
                                </aq:If>
                                <aq:If Condition="{aq:SlotProvided}">
                                    <Border Padding="8">
                                        <ContentPresenter Content="{aq:SlotContent}" />
                                    </Border>
                                </aq:If>
                                <aq:If Condition="{aq:SlotProvided footer}">
                                    <Border Background="#F0F0F0"
                                            Padding="8">
                                        <ContentPresenter Content="{aq:SlotContent footer}" />
                                    </Border>
                                </aq:If>
                            </StackPanel>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <StackPanel Margin="12">
        <TextBlock TextWrapping="Wrap"
                   Margin="0,0,0,4"
                   Text="Card derives from SlotHost - header/footer are free-form named slots (no DependencyProperty declared per name), each skipped entirely via SlotProvided+If when not supplied:" />
        <local:Card Margin="0,0,0,12">
            <aq:Slot Name="header">
                <TextBlock Text="Here might be a page title"
                           FontWeight="Bold" />
            </aq:Slot>

            <TextBlock Text="A paragraph for the main content - the default slot, no aq:Slot wrapper needed."
                       TextWrapping="Wrap" />

            <aq:Slot Name="footer">
                <TextBlock Text="Here's some contact info"
                           FontStyle="Italic" />
            </aq:Slot>
        </local:Card>

        <TextBlock TextWrapping="Wrap"
                   Margin="0,0,0,8"
                   Text="Posts is just fetched data; this ItemTemplate is entirely consumer-styled - the same &quot;scoped slot passes data back to the parent's template&quot; idea Vue's FancyList docs example demonstrates. This is the repeated-list case, deliberately not unified with aq:Slot above - a Slot holds one already-realized element, a DataTemplate is re-instantiated per item." />
        <ItemsControl ItemsSource="{Binding Posts}">
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <Border Background="#F5F5F5"
                            Padding="8"
                            Margin="0,0,0,4"
                            CornerRadius="4">
                        <StackPanel>
                            <TextBlock Text="{Binding Body}"
                                       TextWrapping="Wrap" />
                            <TextBlock Margin="0,4,0,0"
                                       FontStyle="Italic"
                                       Opacity="0.7">
                                <Run Text="by " /><Run Text="{Binding Username}" /><Run Text=" &#183; " /><Run Text="{Binding Likes}" /><Run Text=" likes" />
                            </TextBlock>
                        </StackPanel>
                    </Border>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>
    </StackPanel>
</UserControl>
